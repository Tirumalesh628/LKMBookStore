@model BookStore.Models.User

<form class="row g-3" asp-action="Register" asp-controller="User" method="Post">
    
    <div class="mb-3">
        <label for="inputEmail4" class="form-label">Name</label>
        <input asp-for="UserName"  class="form-control" id="inputText">
    </div>
    <div class="mb-3">
        <label for="inputEmail4" class="form-label">Email</label>
        <input asp-for="UserEmail" type="email" class="form-control" id="inputEmail4">
    </div>
    <div class="mb-3">
        <label for="inputEmail4" class="form-label">Phone</label>
        <input asp-for="Phone" class="form-control" id="inputext">
    </div>


    <div class="mb-3">
        <label for="inputPassword4" class="form-label">Password</label>
        <input asp-for="Password" type="password" class="form-control" id="inputPassword4">
    </div>
    
